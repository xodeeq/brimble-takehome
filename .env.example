# API base URL for the UI (Vite). Defaults to http://api.brimble.localhost for compose.
# Set this when deploying the UI to a remote host (e.g. Brimble).
VITE_API_BASE=https://brimble-api.up.railway.app

# SQLite database path — served by the brimble_data named volume
DB_PATH=/data/brimble.db

# API server port (container-internal)
PORT=3000

# Docker socket — mounted from host for Docker-out-of-Docker
DOCKER_SOCKET=/var/run/docker.sock

# Port the API dictates for every deployed app container.
# Railpack-built Node images respect PORT via the start command.
DEPLOYED_APP_PORT=3000
